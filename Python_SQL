import pandas as pd
import matplotlib.pyplot as plt
import io

# 1. Defining the dataset manually to avoid file path errors
data = """Warehouse_ID,City,Energy_Cosumption_Kwh,Transportation_Mode,Distance_KM,Carbon_Emission_KG_Per_KM
WH001,Berlin,4500,Electric,120,0.05
WH002,London,6200,Diesel,350,0.25
WH003,Paris,3800,Electric,90,0.05
WH004,Madrid,7100,Diesel,420,0.25
WH005,Rome,5500,Hybrid,210,0.12
WH006,Berlin,4800,Electric,150,0.05
WH007,London,6900,Diesel,380,0.25
WH008,Paris,4100,Hybrid,110,0.12
WH009,Madrid,7500,Diesel,500,0.25
WH0010,Rome,5200,Electric,180,0.05"""

# 2. Loading the data into a DataFrame
df = pd.read_csv(io.StringIO(data))

# 3. Calculating Total Carbon Footprint (Distance * Emission Factor)
df['Total_Carbon_Footprint'] = df['Distance_KM'] * df['Carbon_Emission_KG_Per_KM']

# 4. Displaying the analysis summary
summary = df.groupby('Transportation_Mode')[['Energy_Cosumption_Kwh', 'Total_Carbon_Footprint']].mean()
print("-- Sustainability Analysis Summary ---")
print(summary)

# 5. Visualizing the results
plt.figure(figsize=(8, 5))
summary['Total_Carbon_Footprint'].plot(kind='bar', color='skyblue', edgecolor='black')
plt.title('Average Carbon Footprint per Transportation Mode')
plt.xlabel('Transportation Mode')
plt.ylabel('Average Carbon Emissions (KG)')
plt.xticks(rotation=0)
plt.grid(axis='y', linestyle='--', alpha=0.7)
plt.show()

