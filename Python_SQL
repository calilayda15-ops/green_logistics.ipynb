from pandasql import sqldf

# 1. Veriyi tanımlayalım (Daha önce oluşturduğumuz DataFrame 'df')
# df = pd.read_csv(...) # Verinin zaten yüklü olduğunu varsayıyoruz

# 2. SQL sorgumuzu yazalım
# Bu sorgu, taşıma moduna göre ortalama enerji tüketimi ve karbon ayak izini hesaplar
query = """
SELECT
    Transportation_Mode,
    AVG(Energy_Cosumption_Kwh) AS Avg_Energy_Usage,
    AVG(Distance_KM * Carbon_Emission_KG_Per_KM) AS Avg_Total_Carbon_Footprint
FROM df
GROUP BY Transportation_Mode
"""

# 3. Sorguyu çalıştıralım
result = sqldf(query, locals())

# 4. Sonucu yazdıralım
print("--- SQL-Based Sustainability Analysis ---")
print(result)








